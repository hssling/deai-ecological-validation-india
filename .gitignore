# Data — never commit raw or processed data
data_raw/
data_processed/
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle

# Keep results tables and metadata CSVs, but not raw/processed data CSVs
*.csv
*.tsv
*.xlsx
!results/tables/*.csv
!metadata/*.csv
!anti_ageing_review/results/tables/*.csv
!anti_ageing_review/results/meta_addon/tables/*.csv
!anti_ageing_review/submission_assets/**/tables/*.csv
!anti_ageing_review/metadata/*.csv

# Large binary open-text cache files (download via pipeline)
anti_ageing_review/data_processed/
anti_ageing_review/data_raw/

